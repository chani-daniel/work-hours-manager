# Supabase connection (Settings -> API in the Supabase dashboard).
# Copy this file to .env and fill in your own project's values.
# Both values are safe to expose in the client (the anon key is public).
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
